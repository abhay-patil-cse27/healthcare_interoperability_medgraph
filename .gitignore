data/
mongo_data/
neo4j_data/
qdrant_data/
docker-compose.override.yml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Kiro Agent (local workspace config) ──────────────────────────────────────
.kiro/

# ── AWS ───────────────────────────────────────────────────────────────────────
.aws/
cdk.out/
.cdk.staging/
samconfig.toml

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.patch
*.diff
*.pid
*.seed
*.gz
*.zip
*.tar
*.rar

