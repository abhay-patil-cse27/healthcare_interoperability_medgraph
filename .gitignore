# ══════════════════════════════════════════════════════════════════════════════
# MedGraph AI — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
!.env.example
secrets/
.secrets/
SECRETS.md
**/SECRETS.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
.vite/

# ── IDE & Editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace
*.code-workspace

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ── Docker (local volumes) ────────────────────────────────────────────────────
data/
mongo_data/
neo4j_data/
qdrant_data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Kiro Agent (local workspace config) ──────────────────────────────────────
.kiro/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
