# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.development
!.env.example
secrets/
.secrets/
SECRETS.md
**/SECRETS.md
*.pem
*.key
*.crt
*.p12

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
venv/
env/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.mypy_cache/
.ruff_cache/
.pytype/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
.vite/
.parcel-cache/
.turbo/
.next/
.nuxt/

# ── IDE & Editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace
*.code-workspace
.project
.classpath
.settings/

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
junit.xml
test-results/

